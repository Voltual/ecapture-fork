name: Release

on:
  push:
    branches:
      - master
    tags:
      - "v*"

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  build-on-ubuntu-latest:
    runs-on: ubuntu-latest
    name: Release Linux/Android (amd64/arm64)
    steps:
      - name: Setup Go
        uses: actions/setup-go@v5
        with:
          go-version: '1.24.6'

      - name: Check Release Type
        id: release_type
        run: |
          TAG_NAME=${{ github.ref_name }}
          if [[ "$TAG_NAME" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            echo "IS_PRERELEASE=false" >> $GITHUB_OUTPUT
          elif [[ "$TAG_NAME" =~ (alpha|beta|rc) ]]; then
            echo "IS_PRERELEASE=true" >> $GITHUB_OUTPUT
          else
            echo "IS_PRERELEASE=false" >> $GITHUB_OUTPUT
          fi
        shell: bash

      - name: Install Compilers
        run: |
          sudo cp /etc/apt/sources.list /etc/apt/sources.list.bak
          sudo sed -i 's|http://azure.archive.ubuntu.com/ubuntu|http://archive.ubuntu.com/ubuntu|g' /etc/apt/sources.list
          sudo apt-get update
          sudo apt-get install --yes \
            build-essential \
            pkgconf \
            libelf-dev \
            llvm-14 \
            clang-14 \
            linux-tools-common \
            gcc \
            gcc-aarch64-linux-gnu \
            libpcap-dev \
            git \
            make
          
          # 建立工具软链接
          for tool in "clang" "llc" "llvm-strip" "bpftool"; do
            sudo rm -f /usr/bin/$tool
            sudo ln -s /usr/bin/$tool-14 /usr/bin/$tool || true
          done
        shell: bash

      - name: Checkout Code
        uses: actions/checkout@v4
        with:
          submodules: 'recursive'
          fetch-depth: 0
          # 确保子模块使用 HTTPS 而不是 SSH
          token: ${{ secrets.GITHUB_TOKEN }}

      - name: Fix Submodules (关键修复步骤)
        run: |
          echo "🔍 Checking submodule status before fix..."
          git submodule status
          
          # 手动初始化并更新子模块
          git submodule sync --recursive
          git submodule update --init --recursive --force
          
          # 检查 lib/libpcap 是否成功拉取
          if [ -d "lib/libpcap" ] && [ -f "lib/libpcap/configure" ]; then
            echo "✅ lib/libpcap submodule initialized successfully"
          else
            echo "❌ lib/libpcap submodule is empty, trying alternative method..."
            # 尝试直接克隆
            rm -rf lib/libpcap
            git clone https://github.com/the-tcpdump-group/libpcap.git lib/libpcap
            cd lib/libpcap
            git checkout $(git describe --tags $(git rev-list --tags --max-count=1))
            cd ../..
          fi
          
        shell: bash

      - name: Prepare Custom Kernel Headers
        id: kernel_headers
        run: |
          if [ -f "./kheaders.tar.xz" ]; then
            echo "✅ Found custom kheaders.tar.xz"
            mkdir -p ${{ github.workspace }}/custom_headers
            tar -xvf kheaders.tar.xz -C ${{ github.workspace }}/custom_headers
            
            # 自动定位包含 'include' 目录的实际根路径
            REAL_PATH=$(find ${{ github.workspace }}/custom_headers -name "include" -type d -print -quit | sed 's/\/include$//')
            
            echo "LINUX_SOURCE_PATH=$REAL_PATH" >> $GITHUB_ENV
            echo "KERN_SRC_PATH=$REAL_PATH" >> $GITHUB_ENV
            echo "KERN_BUILD_PATH=$REAL_PATH" >> $GITHUB_ENV
            echo "HAS_CUSTOM_HEADERS=true" >> $GITHUB_OUTPUT
            
            echo "Headers located at: $REAL_PATH"
          else
            echo "⚠️ kheaders.tar.xz not found, falling back to generic build"
            echo "HAS_CUSTOM_HEADERS=false" >> $GITHUB_OUTPUT
          fi
        shell: bash

      - name: Fix ARM64 BPF Headers (修复架构问题)
        if: steps.kernel_headers.outputs.HAS_CUSTOM_HEADERS == 'true'
        run: |
          # 修复 vmlinux.h 软链接问题
          cd kern/bpf/arm64/
          if [ -f vmlinux.h ] && [ "$(cat vmlinux.h)" == "./vmlinux_614.h" ]; then
            echo "🔧 Fixing broken vmlinux.h symlink..."
            rm -f vmlinux.h
            cp vmlinux_614.h vmlinux.h
          fi
          
          # 确保 ARM64 寄存器定义正确
          echo "🔧 Adding ARM64 register fix..."
          cat >> vmlinux.h << 'EOF' || true
          #ifndef __PT_REGS_PARM1
          #define __PT_REGS_PARM1(x) (x->regs[0])
          #endif
          EOF
          cd ../../../
        shell: bash

      - name: Release arm64 (Non-CO-RE / nocore)
        if: steps.kernel_headers.outputs.HAS_CUSTOM_HEADERS == 'true'
        run: |
          # 获取 Clang 内部头文件路径
          CLANG_INTERNAL_INC=$(clang -print-resource-dir)/include
          echo "Clang internal include path: $CLANG_INTERNAL_INC"
          
          # 设置 ARM64 编译环境
          export ARCH=arm64
          export CROSS_COMPILE=aarch64-linux-gnu-
          
          # 编译
          make clean
          make nocore \
            CROSS_ARCH=arm64 \
            SNAPSHOT_VERSION=${{ github.ref_name }} \
            KERNEL_HEADER_GEN="true" \
            EXTRA_CFLAGS_NOCORE="-isystem $CLANG_INTERNAL_INC -D__KERNEL__ -D__BPF_TRACING__ -D__TARGET_ARCH_arm64" \
            LINUX_SOURCE_PATH=${{ env.LINUX_SOURCE_PATH }} \
            KERN_SRC_PATH=${{ env.KERN_SRC_PATH }} \
            KERN_BUILD_PATH=${{ env.KERN_BUILD_PATH }}

          # 检查并重命名
          if [ -f "bin/ecapture" ]; then
            mv bin/ecapture bin/ecapture-${{ github.ref_name }}-linux-arm64-nocore
            echo "✅ Build successful: bin/ecapture-${{ github.ref_name }}-linux-arm64-nocore"
          else
            echo "❌ Build failed: bin/ecapture not found"
            echo "📁 Contents of bin directory:"
            ls -la bin/ || true
            exit 1
          fi
        shell: bash

      - name: Standard Release amd64
        if: steps.kernel_headers.outputs.HAS_CUSTOM_HEADERS == 'false'
        run: |
          make clean
          make -f builder/Makefile.release release SNAPSHOT_VERSION=${{ github.ref_name }}

      - name: Standard Release arm64
        if: steps.kernel_headers.outputs.HAS_CUSTOM_HEADERS == 'false'
        run: |
          make clean
          CROSS_ARCH=arm64 make -f builder/Makefile.release release SNAPSHOT_VERSION=${{ github.ref_name }}

      - name: Publish to GitHub Releases
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          IS_PRERELEASE: ${{ steps.release_type.outputs.IS_PRERELEASE }}
        run: |
          TAG=${{ github.ref_name }}
          # 确保 bin 目录存在，防止 gh 命令报错
          mkdir -p bin
          
          # 列出所有构建产物
          echo "📦 Build artifacts:"
          ls -la bin/
          
          # 上传到 Release
          gh release create $TAG bin/ecapture* \
            --title "Release $TAG" \
            --generate-notes \
            $( [ "$IS_PRERELEASE" = "true" ] && echo "--prerelease" ) || \
          gh release upload $TAG bin/ecapture* --clobber
        shell: bash